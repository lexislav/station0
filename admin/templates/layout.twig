<!doctype html>
<html lang="{{ t.html_lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Admin · {{ app.name }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ app.adminPath }}/assets/admin.css">
    {% block head %}{% endblock %}
</head>
<body class="admin">
<div class="admin-layout">
    <aside class="admin-sidebar">
        <a class="sidebar-brand" href="{{ app.adminPath }}">{{ app.name }}</a>
        <nav class="sidebar-nav">
            <a href="{{ app.adminPath }}">{{ t.nav_dashboard }}</a>
            <a href="{{ app.adminPath }}/pages">{{ t.nav_structure }}</a>
            {% if has_streams() %}
                <a href="{{ app.adminPath }}/pages?view=streams">{{ t.nav_streams }}</a>
            {% endif %}
            {% if has_collections() %}
                <a href="{{ app.adminPath }}/collections">{{ t.nav_collections }}</a>
            {% endif %}
            {% if user is defined and user.isAdmin %}
                <a href="{{ app.adminPath }}/settings">{{ t.nav_site_settings }}</a>
            {% endif %}
        </nav>
        <div class="sidebar-footer">
            {% if user is defined %}
                <div class="sidebar-user">{{ user.email }}</div>
                <form method="post" action="{{ app.adminPath }}/logout" class="inline">
                    {% if csrf is defined %}
                        <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
                        <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
                    {% endif %}
                    <button type="submit" class="link sidebar-logout">{{ t.nav_logout }}</button>
                </form>
            {% endif %}
            <div class="sidebar-sig">Station0</div>
        </div>
    </aside>
    <main class="admin-main">
        {% block body %}{% endblock %}
    </main>
</div>
<script>
    (function() {
        var ap = '{{ app.adminPath }}';
        var links = document.querySelectorAll('.sidebar-nav a');
        // Track which pathname+search combos are owned by a search-param link
        var searchOwners = {};
        links.forEach(function(a) {
            if (a.search) searchOwners[a.pathname + a.search] = true;
        });
        links.forEach(function(a) {
            var active = false;
            if (a.search) {
                active = location.pathname === a.pathname && location.search === a.search;
            } else if (a.pathname === ap) {
                active = location.pathname === ap || location.pathname === ap + '/';
            } else if (location.pathname.startsWith(a.pathname)) {
                active = !searchOwners[location.pathname + location.search];
            }
            a.classList.toggle('active', active);
        });
    })();
</script>
</body>
</html>
