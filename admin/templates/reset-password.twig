<!doctype html>
<html lang="{{ t.html_lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ t.reset_title }} · {{ app.name }}</title>
    <link rel="stylesheet" href="{{ app.adminPath }}/assets/admin.css">
</head>
<body class="admin login-page">
<form class="login-card" method="post" action="{{ app.adminPath }}/reset-password">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <input type="hidden" name="selector" value="{{ selector }}">
    <input type="hidden" name="token" value="{{ token }}">
    <h1>{{ app.name }}</h1>
    {% if error %}
        <p class="error">{{ error }}</p>
        <a class="link-small" href="{{ app.adminPath }}/forgot-password">{{ t.reset_new_link }}</a>
    {% else %}
        <label>{{ t.reset_new_password }}<input type="password" name="password" minlength="8" autofocus required></label>
        <button type="submit">{{ t.reset_submit }}</button>
    {% endif %}
</form>
</body>
</html>
