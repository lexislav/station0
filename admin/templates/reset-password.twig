<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Nové heslo · {{ app.name }}</title>
    <link rel="stylesheet" href="/assets/admin.css">
</head>
<body class="admin login-page">
<form class="login-card" method="post" action="{{ app.adminPath }}/reset-password">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <input type="hidden" name="selector" value="{{ selector }}">
    <input type="hidden" name="token" value="{{ token }}">
    <h1>{{ app.name }}</h1>
    {% if error %}
        <p class="error">{{ error }}</p>
        <a class="link-small" href="{{ app.adminPath }}/forgot-password">Požádat o nový odkaz</a>
    {% else %}
        <label>Nové heslo<input type="password" name="password" minlength="8" autofocus required></label>
        <button type="submit">Nastavit heslo</button>
    {% endif %}
</form>
</body>
</html>
