<!doctype html>
<html lang="{{ t.html_lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ t.forgot_title }} · {{ app.name }}</title>
    <link rel="stylesheet" href="{{ app.adminPath }}/assets/admin.css">
</head>
<body class="admin login-page">
<form class="login-card" method="post" action="{{ app.adminPath }}/forgot-password">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <h1>{{ app.name }}</h1>
    {% if sent %}
        <p class="success">{{ t.forgot_sent }}</p>
    {% else %}
        {% if error %}<p class="error">{{ error }}</p>{% endif %}
        <label>{{ t.forgot_email }}<input type="email" name="email" autofocus required></label>
        <button type="submit">{{ t.forgot_submit }}</button>
    {% endif %}
    <a class="link-small" href="{{ app.adminPath }}/login">{{ t.forgot_back }}</a>
</form>
</body>
</html>
