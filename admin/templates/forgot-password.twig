<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Zapomenuté heslo · {{ app.name }}</title>
    <link rel="stylesheet" href="/assets/admin.css">
</head>
<body class="admin login-page">
<form class="login-card" method="post" action="{{ app.adminPath }}/forgot-password">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <h1>{{ app.name }}</h1>
    {% if sent %}
        <p class="success">Pokud e-mail existuje, obdržíte odkaz pro reset hesla.</p>
    {% else %}
        {% if error %}<p class="error">{{ error }}</p>{% endif %}
        <label>E-mail<input type="email" name="email" autofocus required></label>
        <button type="submit">Odeslat odkaz</button>
    {% endif %}
    <a class="link-small" href="{{ app.adminPath }}/login">Zpět na přihlášení</a>
</form>
</body>
</html>
