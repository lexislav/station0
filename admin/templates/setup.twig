<!doctype html>
<html lang="{{ t.html_lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ t.setup_title }} · {{ app.name }}</title>
    <link rel="stylesheet" href="{{ app.adminPath }}/assets/admin.css">
</head>
<body class="admin login-page">
<form class="login-card" method="post" action="{{ app.adminPath }}/setup">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <h1>{{ app.name }}</h1>
    <p class="setup-intro">{{ t.setup_intro }}</p>
    {% if error %}<p class="error">{{ error }}</p>{% endif %}
    <label>{{ t.setup_username }}<input type="text" name="username" value="{{ username ?? '' }}" autofocus required autocomplete="username"></label>
    <label>{{ t.setup_email }}<input type="email" name="email" value="{{ email ?? '' }}" required autocomplete="email"></label>
    <label>{{ t.setup_password }}<input type="password" name="password" required minlength="8" autocomplete="new-password"></label>
    <button type="submit">{{ t.setup_submit }}</button>
</form>
</body>
</html>
