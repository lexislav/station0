{% extends '@admin/layout.twig' %}
{% block head %}
<link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css">
<style>
/* ── Page builder ─────────────────────────────────────────────────────── */
.page-builder { margin-top: 1.5rem; }

.block-item {
    border: 1px solid #dde1e7;
    border-radius: 6px;
    margin-bottom: .75rem;
    background: #fff;
}
.block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .45rem .75rem;
    background: #f4f6f9;
    border-bottom: 1px solid #dde1e7;
    border-radius: 6px 6px 0 0;
    cursor: pointer;
}
.block-label { font-size: .8rem; font-weight: 600; text-transform: uppercase; color: #5a6478; letter-spacing: .04em; }
.block-actions { display: flex; gap: .25rem; }
.block-btn {
    background: none;
    border: 1px solid #c8cdd6;
    border-radius: 4px;
    width: 26px; height: 26px;
    font-size: .85rem;
    cursor: pointer;
    color: #5a6478;
    line-height: 1;
}
.block-btn:hover { background: #e8ebf0; }
.block-btn.block-remove:hover { background: #ffe4e4; border-color: #f9a0a0; color: #c0392b; }

/* ── Block collapse ────────────────────────────────────────────────────── */
.block-item.collapsed .block-fields { display: none; }
.block-item.collapsed .block-header { border-bottom: none; border-radius: 6px; }
.block-toggle {
    font-size: .75rem;
    color: #8a94a6;
    margin-left: .35rem;
    flex-shrink: 0;
    line-height: 1;
    display: inline-block;
    transition: transform .15s ease;
    user-select: none;
}
.block-item.collapsed .block-toggle { transform: rotate(-90deg); }

.block-fields { padding: .75rem; display: flex; flex-direction: column; gap: .6rem; }

.block-add-bar {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
    padding: .6rem .75rem;
    border: 1px dashed #c8cdd6;
    border-radius: 6px;
    background: #f9fafb;
    margin-top: .25rem;
}

/* ── List field (repeater) ─────────────────────────────────────────────── */
.list-field { display: flex; flex-direction: column; gap: .5rem; }
.list-item {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    align-items: flex-start;
    padding: .5rem;
    background: #f4f6f9;
    border-radius: 4px;
    border: 1px solid #e2e6ec;
}
.list-item .field { flex: 1; min-width: 140px; margin: 0; }
.list-item .field--img { flex: 0 0 auto; min-width: 0; }
.list-item-remove { flex-shrink: 0; }
.list-item-btns { display: flex; gap: .35rem; align-items: flex-end; flex-shrink: 0; margin-left: auto; }
@media (min-width: 768px) {
    .list-item { align-items: center; }
    .list-item-btns { align-items: center; }
}

/* ── Input with upload button ──────────────────────────────────────────── */
.input-with-btn { display: flex; gap: .4rem; align-items: center; }
.input-with-btn input[type="text"] { flex: 1; }

/* ── Image thumbnail widget (gallery list items) ───────────────────────── */
.img-thumb-upload { display: inline-flex; flex-direction: column; align-items: flex-start; gap: .3rem; }
.img-thumb-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: .3rem;
    cursor: pointer;
}
.img-thumb-wrap img {
    width: 80px; height: 80px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid #dde1e7;
    display: block;
    background: #e8ebf0;
}
.img-thumb-placeholder {
    width: 80px; height: 80px;
    border-radius: 4px;
    border: 2px dashed #c8cdd6;
    display: flex; align-items: center; justify-content: center;
    background: #f4f6f9;
    color: #8a94a6;
    font-size: .7rem;
    text-align: center;
    box-sizing: border-box;
}
.img-thumb-name {
    font-size: .72rem; color: #5a6478;
    max-width: 80px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* ── Gallery multi-upload ──────────────────────────────────────────────── */
.gallery-uploader {
    display: flex; align-items: center; justify-content: center; gap: .4rem;
    padding: .9rem;
    border: 2px dashed #c8cdd6;
    border-radius: 6px;
    background: #f9fafb;
    color: #5a6478;
    font-size: .82rem;
    font-weight: 500;
    cursor: pointer;
    transition: background .12s, border-color .12s, color .12s;
}
.gallery-uploader:hover { background: #eef1f5; border-color: #aab1bd; color: #2c3e50; }
.list-field--images.drag-over { outline: 2px dashed #2c3e50; outline-offset: 3px; }
.list-field--images.drag-over .gallery-uploader {
    border-color: #2c3e50;
    background: #eaf1f8;
    color: #2c3e50;
}
.img-thumb-upload.uploading .img-thumb-wrap { position: relative; cursor: default; }
.img-thumb-upload.uploading img { opacity: .55; }
.img-thumb-progress {
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 6px;
    background: rgba(0,0,0,.3);
    border-radius: 0 0 4px 4px;
    overflow: hidden;
}
.img-thumb-progress-bar {
    display: block; height: 100%; width: 0;
    background: #3a7bd5;
    transition: width .15s ease;
}

/* ── Files multi-upload drop zone ─────────────────────────────────────── */
.files-uploader {
    display: flex; align-items: center; justify-content: center; gap: .4rem;
    padding: .9rem;
    border: 2px dashed #c8cdd6;
    border-radius: 6px;
    background: #f9fafb;
    color: #5a6478;
    font-size: .82rem;
    font-weight: 500;
    cursor: pointer;
    transition: background .12s, border-color .12s, color .12s;
}
.files-uploader:hover { background: #eef1f5; border-color: #aab1bd; color: #2c3e50; }
.list-field--files.drag-over { outline: 2px dashed #2c3e50; outline-offset: 3px; }
.list-field--files.drag-over .files-uploader {
    border-color: #2c3e50;
    background: #eaf1f8;
    color: #2c3e50;
}

/* ── ToastUI: no inner wrapper, floating toolbar dock ──────────────────── */
.block-editor .toastui-editor-defaultUI {
    border: none;
    box-shadow: none;
}
.block-editor .toastui-editor-toolbar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    background: rgba(248, 249, 251, .97);
    backdrop-filter: blur(6px);
    border: none;
    border-bottom: 1px solid #e8eaee;
    border-radius: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
}
/* Mode-switch re-parented into block header: split-button look, sits next to label */
.block-header .toastui-editor-mode-switch {
    display: flex;
    flex-shrink: 0;
    margin: 0;   /* let block-header's justify-content: space-between center it */
    height: auto;
    min-height: 0;
    padding: 0;
    border-radius: 5px;
    overflow: hidden;
    border: 1px solid #c8cdd6;
    background: #fff;
    box-sizing: border-box;
}
.block-header .toastui-editor-mode-switch .tab-item {
    font-size: .7rem;
    padding: 2px 9px;
    margin: 0;
    height: auto;
    min-height: 0;
    border: none;
    border-left: 1px solid #c8cdd6;
    background: #fff;
    cursor: pointer;
    color: #5a6478;
    line-height: 1.7;
    transition: background .1s, color .1s;
    border-radius: 0;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 500;
}
.block-header .toastui-editor-mode-switch .tab-item:first-child { border-left: none; }
.block-header .toastui-editor-mode-switch .tab-item.active { background: #2c3e50; color: #fff; }
.block-header .toastui-editor-mode-switch .tab-item:not(.active):hover { background: #f0f2f5; }
</style>
{% endblock %}

{% block body %}
{% if mode == 'new' %}
    {% set formAction = app.adminPath ~ '/pages/create' %}
{% else %}
    {% set editKey = page.urlPath == '/' ? '~' : page.urlPath|trim('/') %}
    {% set formAction = app.adminPath ~ '/pages/' ~ editKey ~ '/update' %}
{% endif %}

<form method="post" action="{{ formAction }}" class="page-edit" id="page-edit-form">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">

    {% if error %}<p class="error">{{ error }}</p>{% endif %}

    {% if mode == 'edit' %}
        <p class="breadcrumb">
            <a href="{{ app.adminPath }}/pages">Pages</a>
            {% for crumb in breadcrumb %}
                <span>›</span>
                {% if not loop.last %}
                    <a href="{{ app.adminPath }}/pages/{{ crumb.urlPath == '/' ? '~' : crumb.urlPath|trim('/') }}/edit">{{ crumb.title }}</a>
                {% else %}
                    {{ crumb.title }}
                {% endif %}
            {% endfor %}
        </p>
    {% endif %}

    <div class="field">
        <label>Title</label>
        <input type="text" name="title" value="{{ page.title }}" required autofocus>
    </div>

    <div class="row">
        {% if mode == 'new' %}
        <div class="field">
            <label>Slug <small>(optional — generated from title)</small></label>
            <input type="text" name="slug" value="{{ page.slug }}" placeholder="my-page-slug">
        </div>
        <div class="field">
            <label>Parent page</label>
            <select name="parent">
                {% for opt in parents %}
                    <option value="{{ opt.url }}" {% if opt.url == (selectedParent|default('/')) %}selected{% endif %}>{{ opt.label }}</option>
                {% endfor %}
            </select>
        </div>
        {% elseif page.slug != '' %}
        <div class="field">
            <label>Slug <small class="muted">– <code>{{ page.urlPath }}</code></small></label>
            <input type="text" name="slug" value="{{ page.slug }}" placeholder="my-page-slug">
        </div>
        {% endif %}

        <div class="field">
            <label>Template</label>
            {% if availableTemplates is not empty %}
                <select name="template" id="template-select">
                    {% for tpl in availableTemplates %}
                        <option value="{{ tpl }}" {% if tpl == (page.template|default('page')) %}selected{% endif %}>{{ tpl }}</option>
                    {% endfor %}
                </select>
            {% else %}
                <input type="text" name="template" value="{{ page.template|default('page') }}">
            {% endif %}
        </div>
    </div>

    <div class="field">
        <label>Meta title <small>(used for HTML &lt;title&gt; — falls back to Title if empty)</small></label>
        <input type="text" name="metatitle" value="{{ page.metatitle }}" placeholder="{{ page.title }}">
    </div>

    <div class="row">
        <div class="field checkbox">
            <label>
                <input type="checkbox" name="published" value="1" {% if page.published %}checked{% endif %}>
                Published
            </label>
        </div>
        <div class="field">
            <label>Publish date <small>(future date = scheduled)</small></label>
            <input type="datetime-local" name="published_at"
                   value="{{ page.publishedAt ? page.publishedAt|date('Y-m-d\\TH:i') : '' }}">
        </div>
    </div>

    {# ════════════════════════════════════════════════════════════════════
       Page builder – ordered list of content blocks
       ════════════════════════════════════════════════════════════════════ #}
    <div class="page-builder">
        <div id="block-list">
            {% for i, block in blocks %}
                {% include '@admin/pages/_block_item.twig' with {block: block, id: i} %}
            {% endfor %}
        </div>
        <div class="block-add-bar">
            <span class="muted" style="font-size:.85rem">+ Add block:</span>
            {% for bt in blockTypes %}
                <button type="button" class="btn btn-sm block-type-btn"
                        data-type="{{ bt.type }}">{{ bt.label }}</button>
            {% endfor %}
        </div>
    </div>

    {# Serialised body – filled by JS before submit #}
    <textarea name="body" id="body-field" hidden></textarea>

    {# ── Block templates for JS cloning (server-rendered, one per type) ── #}
    {% for bt in blockTypes %}
    <template id="block-tpl-{{ bt.type }}">
        {% include '@admin/pages/_block_item.twig' with {block: {type: bt.type}, id: '__ID__'} %}
    </template>
    {% endfor %}

    {# Block type schemas for JS (add-list-item, etc.) #}
    <script id="block-schemas" type="application/json">{{ blockTypes|json_encode|raw }}</script>

    <div class="toolbar sticky">
        <a class="btn" href="{{ app.adminPath }}/pages">Cancel</a>
        <button type="submit" class="btn primary" id="save-btn" disabled>Save</button>
    </div>
</form>

<script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
<script>
(function () {
    const form       = document.getElementById('page-edit-form');
    const bodyField  = document.getElementById('body-field');
    const blockList  = document.getElementById('block-list');
    const schemas    = JSON.parse(document.getElementById('block-schemas').textContent);

    const csrf = {
        nameKey:  '{{ csrf.nameKey }}',
        name:     '{{ csrf.name }}',
        valueKey: '{{ csrf.valueKey }}',
        value:    '{{ csrf.value }}'
    };

    // URL path of the page being edited; empty when creating a new page.
    const pagePath = {{ (mode == 'edit' ? page.urlPath : '')|json_encode|raw }};

    // Counter ensures unique IDs for dynamically added blocks.
    // Starts after the server-rendered blocks so there are no collisions.
    let blockCounter = {{ blocks|length }};

    const collapseMode = {{ app.blockCollapse|json_encode|raw }};
    const lsKey = 's0_blk_' + (pagePath || '__new__');

    // blockId (string) → ToastUI Editor instance
    const editors = {};

    const isNew   = {{ (mode == 'new')|json_encode|raw }};
    const saveBtn = document.getElementById('save-btn');
    function enableSave() { if (saveBtn) saveBtn.disabled = false; }

    // ── ToastUI ────────────────────────────────────────────────────────────

    function initTextEditor(blockEl) {
        const editorDiv = blockEl.querySelector('.block-editor');
        const textarea  = blockEl.querySelector('[data-field="body"]');
        const id        = blockEl.dataset.blockId;
        if (!editorDiv || !textarea || editors[id]) return;

        editors[id] = new toastui.Editor({
            el: editorDiv,
            height: '280px',
            initialEditType: 'wysiwyg',
            previewStyle: 'tab',
            usageStatistics: false,
            initialValue: textarea.value,
            events: { change: enableSave },
            hooks: {
                addImageBlobHook: async (blob, callback) => {
                    const result = await uploadFile(blob);
                    // Store the bare filename in markdown so the reference
                    // survives if the page is moved later.
                    if (result) callback(result.filename, blob.name || 'image');
                }
            }
        });

        // Move the original mode-switch out of the editor and into the block header,
        // alongside other block-level meta-actions (move/delete). Keeps the toolbar
        // free to grow in markdown mode without pushing the switcher off-screen.
        const header     = blockEl.querySelector('.block-header');
        const actions    = header && header.querySelector('.block-actions');
        const modeSwitch = editorDiv.querySelector('.toastui-editor-mode-switch');
        if (header && actions && modeSwitch) {
            header.insertBefore(modeSwitch, actions);
        }
    }

    function destroyTextEditor(blockEl) {
        const id = blockEl.dataset.blockId;
        if (editors[id]) { editors[id].destroy(); delete editors[id]; }
    }

    function syncTextEditors() {
        document.querySelectorAll('.block-item[data-type="text"]').forEach(blockEl => {
            const ed = editors[blockEl.dataset.blockId];
            if (ed) blockEl.querySelector('[data-field="body"]').value = ed.getMarkdown();
        });
    }

    // Initialise editors for all blocks present on page load
    document.querySelectorAll('.block-item[data-type="text"]').forEach(initTextEditor);

    // ── Block management ───────────────────────────────────────────────────

    function addBlock(type) {
        const id  = blockCounter++;
        const tpl = document.getElementById('block-tpl-' + type);
        if (!tpl) return;

        // Clone template, swap the __ID__ placeholder, append
        const tmpDiv      = document.createElement('div');
        const cloned      = tpl.content.cloneNode(true);
        tmpDiv.appendChild(cloned);
        tmpDiv.innerHTML  = tmpDiv.innerHTML.replace(/__ID__/g, String(id));
        const blockEl     = tmpDiv.firstElementChild;
        blockEl.dataset.blockId = String(id);

        blockList.appendChild(blockEl);

        if (type === 'text') initTextEditor(blockEl);
        initNewBlockCollapse(blockEl);
    }

    function removeBlock(blockEl) {
        destroyTextEditor(blockEl);
        blockEl.remove();
    }

    function moveBlock(blockEl, dir) {
        const prev = blockEl.previousElementSibling;
        const next = blockEl.nextElementSibling;
        if (dir === 'up'   && prev) blockList.insertBefore(blockEl, prev);
        if (dir === 'down' && next) blockList.insertBefore(next, blockEl);
    }

    // ── Block collapse ─────────────────────────────────────────────────────

    function setCollapsed(blockEl, collapsed) {
        blockEl.classList.toggle('collapsed', collapsed);
    }

    function loadCollapseState() {
        try { return JSON.parse(localStorage.getItem(lsKey) || 'null'); }
        catch { return null; }
    }

    function saveCollapseState() {
        const states = Array.from(blockList.children).map(el => el.classList.contains('collapsed'));
        try { localStorage.setItem(lsKey, JSON.stringify(states)); }
        catch { /* storage full or private mode — ignore */ }
    }

    function initCollapseStates() {
        const items = Array.from(blockList.children);
        if (collapseMode === 'collapsed') {
            items.forEach(el => setCollapsed(el, true));
        } else if (collapseMode === 'remember') {
            const saved = loadCollapseState();
            if (saved) items.forEach((el, i) => setCollapsed(el, saved[i] === true));
        }
        // 'open': nothing to do
    }

    function initNewBlockCollapse(blockEl) {
        if (collapseMode === 'collapsed') setCollapsed(blockEl, true);
        // 'open' and 'remember' (no prior state for new block): start open
    }

    initCollapseStates();

    // ── Pre-fill empty captions from image filename ────────────────────────
    function filenameToCaption(src) {
        return src.split('/').pop().split('?')[0].replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ').trim();
    }
    document.querySelectorAll('.list-item').forEach(item => {
        const srcInput     = item.querySelector('input[data-subfield="src"]');
        const captionInput = item.querySelector('input[data-subfield="caption"]');
        if (srcInput && captionInput && srcInput.value && !captionInput.value) {
            captionInput.value = filenameToCaption(srcInput.value);
        }
    });

    // ── List-item repeater ─────────────────────────────────────────────────

    function createListItem(itemFields) {
        const div = document.createElement('div');
        div.className = 'list-item';
        let html = '';
        (itemFields || []).forEach(sf => {
            if (sf.type === 'image') {
                html += `<div class="field field--img">`
                      + `<div class="img-thumb-upload">`
                      + `<input type="hidden" data-subfield="${sf.name}" value="">`
                      + `<label class="img-thumb-wrap" title="Click to upload image">`
                      + `<span class="img-thumb-placeholder">Upload<br>image</span>`
                      + `</label>`
                      + `<input type="file" class="upload-file-input" hidden accept="image/*,.svg">`
                      + `</div></div>`;
            } else if (sf.type === 'file') {
                html += `<div class="field">`
                      + `<label>${sf.label}</label>`
                      + `<div class="file-upload-widget" data-field="${sf.name}">`
                      + `<div class="input-with-btn">`
                      + `<input type="text" data-subfield="${sf.name}" value="" placeholder="document.pdf" readonly>`
                      + `<button type="button" class="btn btn-sm file-upload-trigger">Upload</button>`
                      + `<button type="button" class="btn btn-sm file-upload-clear" style="display:none">× Clear</button>`
                      + `</div>`
                      + `<input type="file" class="file-upload-input" hidden`
                      + ` accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.odt,.ods,.odp,.csv,.txt,.rtf,.zip,.gz,.tar,.7z,.rar,.mp3,.wav,.ogg,.mp4,.webm,.json,.xml,.md">`
                      + `<p class="file-upload-name" style="margin:.35rem 0 0;font-size:.82rem;color:#5a6478;display:none;"></p>`
                      + `</div></div>`;
            } else {
                html += `<div class="field"><label>${sf.label}</label>`
                      + `<input type="text" data-subfield="${sf.name}" value=""></div>`;
            }
        });
        html += `<div class="list-item-btns">`
              + `<button type="button" class="btn btn-sm list-item-remove">✕ Remove</button>`
              + `</div>`;
        div.innerHTML = html;
        return div;
    }

    // ── Upload ─────────────────────────────────────────────────────────────

    /**
     * Upload a file. Returns { filename, url } on success, null on failure.
     * `filename` is what we store in content (page-local reference); `url`
     * is only useful for previews / ToastUI inline display.
     * `onProgress` (optional) receives a 0–1 fraction during the upload.
     */
    function uploadFile(file, onProgress) {
        return new Promise(resolve => {
            if (!pagePath) {
                alert('Save the page first — files are stored in the page folder.');
                resolve(null);
                return;
            }
            const fd = new FormData();
            fd.append('file', file);
            fd.append('pagePath', pagePath);
            fd.append(csrf.nameKey, csrf.name);
            fd.append(csrf.valueKey, csrf.value);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '{{ app.adminPath }}/upload');
            xhr.withCredentials = true;

            if (onProgress) {
                xhr.upload.addEventListener('progress', ev => {
                    if (ev.lengthComputable) onProgress(ev.loaded / ev.total);
                });
            }
            xhr.addEventListener('load', () => {
                let json = {};
                try { json = JSON.parse(xhr.responseText); } catch { /* non-JSON body */ }
                if (xhr.status >= 200 && xhr.status < 300 && json.filename) {
                    resolve({ filename: json.filename, url: json.url });
                } else {
                    alert('Upload failed: ' + (json.error || xhr.status));
                    resolve(null);
                }
            });
            xhr.addEventListener('error', () => { alert('Upload failed: network error'); resolve(null); });
            xhr.send(fd);
        });
    }

    // ── Gallery multi-upload ───────────────────────────────────────────────

    /**
     * Build a list-item already showing a local preview of `file` with a
     * progress-bar overlay, ready to be inserted while the upload runs.
     */
    function createUploadingItem(itemFields, file) {
        const div     = createListItem(itemFields);
        const imgWrap = div.querySelector('.img-thumb-upload');
        if (imgWrap) {
            imgWrap.classList.add('uploading');
            const thumbWrap   = imgWrap.querySelector('.img-thumb-wrap');
            const placeholder = thumbWrap.querySelector('.img-thumb-placeholder');
            const img = document.createElement('img');
            img.src = URL.createObjectURL(file);
            img.alt = file.name;
            if (placeholder) thumbWrap.replaceChild(img, placeholder);
            const prog = document.createElement('span');
            prog.className = 'img-thumb-progress';
            prog.innerHTML = '<span class="img-thumb-progress-bar"></span>';
            thumbWrap.appendChild(prog);
        }
        return div;
    }

    /** Upload one file into an already-inserted uploading row. */
    async function uploadOneIntoRow(file, row) {
        const imgWrap = row.querySelector('.img-thumb-upload');
        const bar     = imgWrap && imgWrap.querySelector('.img-thumb-progress-bar');
        const result  = await uploadFile(file, frac => {
            if (bar) bar.style.width = Math.round(frac * 100) + '%';
        });
        if (!result) { row.remove(); return; }

        const hidden = imgWrap.querySelector('input[type="hidden"][data-subfield]');
        if (hidden) hidden.value = result.filename;

        const img = imgWrap.querySelector('.img-thumb-wrap img');
        if (img) {
            const oldSrc = img.src;
            img.src = result.url;
            img.alt = result.filename;
            if (oldSrc.startsWith('blob:')) URL.revokeObjectURL(oldSrc);
        }
        const prog = imgWrap.querySelector('.img-thumb-progress');
        if (prog) prog.remove();
        imgWrap.classList.remove('uploading');

        const captionInput = row.querySelector('[data-subfield="caption"]');
        if (captionInput && !captionInput.value) {
            captionInput.value = filenameToCaption(result.filename);
        }
    }

    /** Create populated rows for each image file and upload them in parallel. */
    function uploadToGallery(listEl, files) {
        if (!listEl) return;
        if (!pagePath) {
            alert('Save the page first — files are stored in the page folder.');
            return;
        }
        const subFields = JSON.parse(listEl.dataset.itemFields || '[]');
        if (!subFields.some(sf => sf.type === 'image')) return;

        const images = Array.from(files).filter(
            f => f.type.startsWith('image/') || /\.svg$/i.test(f.name)
        );
        if (!images.length) { alert('Please select image files.'); return; }

        const uploader = listEl.querySelector('.gallery-uploader');
        enableSave();
        images.forEach(file => {
            const row = createUploadingItem(subFields, file);
            listEl.insertBefore(row, uploader);
            uploadOneIntoRow(file, row);
        });
    }

    // ── File list multi-upload ────────────────────────────────────────────

    /**
     * Create a list-item row showing a pending file — name + spinner — ready
     * to be inserted before the upload finishes so the UI feels instant.
     */
    function createUploadingFileItem(itemFields, file) {
        const div = createListItem(itemFields);
        // Show the filename immediately in the text input so the user gets
        // instant feedback even before the XHR completes.
        const inp = div.querySelector('input[type="text"][data-subfield]');
        if (inp) inp.value = '⏳ ' + file.name;
        return div;
    }

    /** Upload one file into an already-inserted file-list row. */
    async function uploadOneFileIntoRow(file, row) {
        const result = await uploadFile(file);
        if (!result) { row.remove(); return; }

        const inp    = row.querySelector('input[type="text"][data-subfield]');
        if (inp) inp.value = result.filename;

        const widget = row.querySelector('.file-upload-widget');
        if (widget) {
            const nameEl  = widget.querySelector('.file-upload-name');
            const clearBtn = widget.querySelector('.file-upload-clear');
            if (nameEl)   { nameEl.textContent = '📎 ' + result.filename; nameEl.style.display = ''; }
            if (clearBtn) clearBtn.style.display = 'inline-block';
        }
    }

    /** Upload multiple document files into a list-field--files container. */
    function uploadToFileList(listEl, files) {
        if (!listEl) return;
        if (!pagePath) {
            alert('Save the page first — files are stored in the page folder.');
            return;
        }
        const subFields = JSON.parse(listEl.dataset.itemFields || '[]');
        if (!subFields.some(sf => sf.type === 'file')) return;

        if (!files.length) return;

        const uploader = listEl.querySelector('.files-uploader');
        enableSave();
        Array.from(files).forEach(file => {
            const row = createUploadingFileItem(subFields, file);
            listEl.insertBefore(row, uploader);
            uploadOneFileIntoRow(file, row);
        });
    }

    // ── Event delegation ───────────────────────────────────────────────────

    document.addEventListener('click', async e => {
        // Block header actions
        const removeBtn = e.target.closest('.block-remove');
        const upBtn     = e.target.closest('.block-up');
        const downBtn   = e.target.closest('.block-down');
        if (removeBtn) { removeBlock(removeBtn.closest('.block-item')); return; }
        if (upBtn)     { moveBlock(upBtn.closest('.block-item'), 'up'); return; }
        if (downBtn)   { moveBlock(downBtn.closest('.block-item'), 'down'); return; }

        // Add block
        if (e.target.matches('.block-type-btn')) { addBlock(e.target.dataset.type); return; }

        // List items
        if (e.target.matches('.list-item-add')) {
            const listEl    = e.target.closest('.list-field');
            const subFields = JSON.parse(listEl.dataset.itemFields || '[]');
            listEl.insertBefore(createListItem(subFields), e.target);
            return;
        }
        if (e.target.matches('.list-item-remove')) { e.target.closest('.list-item').remove(); return; }

        // Upload button (top-level image field) → trigger hidden file input
        if (e.target.matches('.upload-trigger')) {
            const fileInput = e.target.closest('.input-with-btn')?.querySelector('.upload-file-input');
            if (fileInput) fileInput.click();
            return;
        }
        // Clicking the thumbnail (or placeholder) also triggers upload
        if (e.target.closest('.img-thumb-wrap')) {
            const wrap = e.target.closest('.img-thumb-upload');
            if (wrap.classList.contains('uploading')) return;
            wrap.querySelector('.upload-file-input').click();
            return;
        }

        // File field: upload trigger
        if (e.target.matches('.file-upload-trigger')) {
            const widget = e.target.closest('.file-upload-widget');
            if (widget) widget.querySelector('.file-upload-input').click();
            return;
        }
        // File field: clear button
        if (e.target.matches('.file-upload-clear')) {
            const widget  = e.target.closest('.file-upload-widget');
            if (!widget) return;
            const inp = widget.querySelector('input[type="text"][data-field], input[type="text"][data-subfield]');
            if (inp) inp.value = '';
            const nameEl = widget.querySelector('.file-upload-name');
            if (nameEl) { nameEl.textContent = ''; nameEl.style.display = 'none'; }
            e.target.style.display = 'none';
            enableSave();
            return;
        }
    });

    // ── Gallery drag & drop ────────────────────────────────────────────────

    function galleryDropZone(target) {
        return target && target.closest ? target.closest('.list-field--images') : null;
    }

    document.addEventListener('dragover', e => {
        const zone = galleryDropZone(e.target);
        if (!zone) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'copy';
        zone.classList.add('drag-over');
    });
    document.addEventListener('dragleave', e => {
        const zone = galleryDropZone(e.target);
        if (zone && !zone.contains(e.relatedTarget)) zone.classList.remove('drag-over');
    });
    document.addEventListener('drop', e => {
        const zone = galleryDropZone(e.target);
        if (!zone) return;
        e.preventDefault();
        zone.classList.remove('drag-over');
        if (e.dataTransfer.files.length) uploadToGallery(zone, e.dataTransfer.files);
    });

    // ── File-list drag & drop ──────────────────────────────────────────────

    function fileListDropZone(target) {
        return target && target.closest ? target.closest('.list-field--files') : null;
    }

    document.addEventListener('dragover', e => {
        const zone = fileListDropZone(e.target);
        if (!zone) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'copy';
        zone.classList.add('drag-over');
    });
    document.addEventListener('dragleave', e => {
        const zone = fileListDropZone(e.target);
        if (zone && !zone.contains(e.relatedTarget)) zone.classList.remove('drag-over');
    });
    document.addEventListener('drop', e => {
        const zone = fileListDropZone(e.target);
        if (!zone) return;
        e.preventDefault();
        zone.classList.remove('drag-over');
        if (e.dataTransfer.files.length) uploadToFileList(zone, e.dataTransfer.files);
    });

    blockList.addEventListener('dblclick', e => {
        const header = e.target.closest('.block-header');
        if (!header) return;
        if (e.target.closest('.block-actions')) return;
        if (e.target.closest('.toastui-editor-mode-switch')) return;

        const blockEl = header.closest('.block-item');
        if (!blockEl) return;

        setCollapsed(blockEl, !blockEl.classList.contains('collapsed'));
        if (collapseMode === 'remember') saveCollapseState();
    });

    document.addEventListener('change', async e => {
        // Gallery multi-upload input → create populated rows
        if (e.target.matches('.gallery-upload-input')) {
            uploadToGallery(e.target.closest('.list-field'), e.target.files);
            e.target.value = '';
            return;
        }

        // File list multi-upload input → create populated rows
        if (e.target.matches('.files-upload-input')) {
            uploadToFileList(e.target.closest('.list-field'), e.target.files);
            e.target.value = '';
            return;
        }

        // File field upload input
        if (e.target.matches('.file-upload-input')) {
            const file   = e.target.files[0];
            const widget = e.target.closest('.file-upload-widget');
            if (!file || !widget) { e.target.value = ''; return; }
            const result = await uploadFile(file);
            if (result) {
                // Works for both top-level fields (data-field) and list subfields (data-subfield).
                const inp = widget.querySelector('input[type="text"][data-field], input[type="text"][data-subfield]');
                if (inp) inp.value = result.filename;
                const nameEl = widget.querySelector('.file-upload-name');
                if (nameEl) { nameEl.textContent = '📎 ' + result.filename; nameEl.style.display = ''; }
                const clearBtn = widget.querySelector('.file-upload-clear');
                if (clearBtn) clearBtn.style.display = 'inline-block';
                enableSave();
            }
            e.target.value = '';
            return;
        }

        if (!e.target.matches('.upload-file-input')) return;
        const file = e.target.files[0];
        if (!file) return;
        const result = await uploadFile(file);
        if (result) {
            const wrap = e.target.closest('.img-thumb-upload');
            if (wrap) {
                wrap.querySelector('input[type="hidden"][data-subfield]').value = result.filename;
                const thumbWrap = wrap.querySelector('.img-thumb-wrap');
                let img = thumbWrap.querySelector('img');
                if (!img) {
                    const placeholder = thumbWrap.querySelector('.img-thumb-placeholder');
                    img = document.createElement('img');
                    img.alt = result.filename;
                    thumbWrap.replaceChild(img, placeholder);
                }
                img.src = result.url;
                img.alt = result.filename;
                // Auto-fill caption from filename if field exists and is empty
                const captionInput = e.target.closest('.list-item')?.querySelector('[data-subfield="caption"]');
                if (captionInput && !captionInput.value) {
                    captionInput.value = filenameToCaption(result.filename);
                }
            } else {
                // fallback: top-level image fields still use .input-with-btn
                const ibWrap = e.target.closest('.input-with-btn');
                if (ibWrap) ibWrap.querySelector('input[type="text"]').value = result.filename;
            }
        }
        e.target.value = '';
    });

    // ── Serialisation → YAML → hidden field ───────────────────────────────

    function collectBlocks() {
        const blocks = [];
        document.querySelectorAll('.block-item').forEach(blockEl => {
            const block = { type: blockEl.dataset.type };

            // Scalar fields (skip anything nested inside a .list-item)
            blockEl.querySelectorAll('input[data-field], select[data-field], textarea[data-field]')
                .forEach(el => {
                    if (el.closest('.list-item')) return;
                    const name = el.dataset.field;
                    block[name] = el.type === 'checkbox' ? el.checked : el.value;
                });

            // List fields
            blockEl.querySelectorAll('.list-field[data-field]').forEach(listEl => {
                const name = listEl.dataset.field;
                block[name] = [];
                listEl.querySelectorAll('.list-item').forEach(itemEl => {
                    const item = {};
                    itemEl.querySelectorAll('[data-subfield]').forEach(sf => {
                        item[sf.dataset.subfield] = sf.value;
                    });
                    block[name].push(item);
                });
            });

            blocks.push(block);
        });
        return blocks;
    }

    form.addEventListener('submit', () => {
        syncTextEditors();
        bodyField.value = jsyaml.dump(collectBlocks(), { lineWidth: -1 });
    });

    // Slug input: auto-sanitize on blur (mirrors PHP Slug::sanitize).
    function sanitizeSlug(value) {
        return value
            .normalize('NFD').replace(/[̀-ͯ]/g, '')
            .toLowerCase()
            .replace(/[^a-z0-9\-_]+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^[-_]+|[-_]+$/g, '');
    }
    form.querySelectorAll('input[name="slug"]').forEach(input => {
        input.addEventListener('blur', () => {
            const cleaned = sanitizeSlug(input.value);
            if (cleaned !== input.value) input.value = cleaned;
        });
    });

    // ── Save button dirty tracking ─────────────────────────────────────────
    const titleInput = form.querySelector('input[name="title"]');
    const slugInput  = form.querySelector('input[name="slug"]');

    if (isNew) {
        // Enable save only when title is non-empty.
        if (titleInput) {
            titleInput.addEventListener('input', () => {
                if (saveBtn) saveBtn.disabled = titleInput.value.trim() === '';
            });
        }
        // Auto-generate slug from title while slug hasn't been manually edited.
        if (titleInput && slugInput) {
            let slugTouched = slugInput.value !== '';
            titleInput.addEventListener('input', () => {
                if (!slugTouched) slugInput.value = sanitizeSlug(titleInput.value);
            });
            slugInput.addEventListener('input', () => {
                const auto = sanitizeSlug(titleInput.value);
                slugTouched = slugInput.value !== '' && slugInput.value !== auto;
            });
        }
    } else {
        // Edit mode: enable save on any form input or change event.
        form.addEventListener('input',  enableSave);
        form.addEventListener('change', enableSave);
    }

    // Cmd+S (Mac) / Ctrl+S (Windows, Linux): save the page.
    document.addEventListener('keydown', e => {
        if ((e.metaKey || e.ctrlKey) && !e.altKey && (e.key === 's' || e.key === 'S')) {
            e.preventDefault();
            form.requestSubmit();
        }
    });

    // ── Parent → template select sync ─────────────────────────────────────
    // Only active on "new page" form where both selects are present.
    const parentSelect   = document.querySelector('select[name="parent"]');
    const templateSelect = document.getElementById('template-select');

    if (parentSelect && templateSelect) {
        parentSelect.addEventListener('change', async () => {
            const parentUrl  = parentSelect.value;
            const current    = templateSelect.value;
            const apiUrl     = '{{ app.adminPath }}/pages/templates?parent=' + encodeURIComponent(parentUrl);

            let templates;
            try {
                const res = await fetch(apiUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) return;
                ({ templates } = await res.json());
            } catch { return; }

            templateSelect.innerHTML = '';
            if (templates.length === 0) return;

            templates.forEach(tpl => {
                const opt    = document.createElement('option');
                opt.value    = tpl;
                opt.textContent = tpl;
                opt.selected = tpl === current;
                templateSelect.appendChild(opt);
            });

            // If the previous selection is no longer available, pick the first option.
            if (!templates.includes(current)) templateSelect.selectedIndex = 0;
        });
    }

})();
</script>
{% endblock %}
