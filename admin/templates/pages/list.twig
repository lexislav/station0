{% extends '@admin/layout.twig' %}
{% block head %}
<style>
.row-actions { position: relative; }
.row-actions summary {
    list-style: none;
    cursor: pointer;
    padding: .2rem .55rem;
    border: 1px solid #c8cdd6;
    border-radius: 4px;
    background: #fff;
    color: #5a6478;
    font-size: .85rem;
    display: inline-block;
}
.row-actions summary::-webkit-details-marker { display: none; }
.row-actions summary:hover { background: #f0f2f5; }
.row-actions[open] summary { background: #e8ebf0; }
.row-actions .menu {
    position: fixed;
    min-width: 160px;
    background: #fff;
    border: 1px solid #dde1e7;
    border-radius: 6px;
    box-shadow: 0 4px 12px rgba(0,0,0,.08);
    padding: .25rem 0;
    z-index: 30;
}
.row-actions .menu a,
.row-actions .menu button {
    display: block;
    width: 100%;
    text-align: left;
    padding: .4rem .75rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #2c3e50;
    font: inherit;
    text-decoration: none;
}
.row-actions .menu a:hover,
.row-actions .menu button:hover { background: #f4f6f9; }
.row-actions .menu .danger { color: #c0392b; }
.row-actions .menu .danger:hover { background: #ffe4e4; }
</style>
{% endblock %}
{% block body %}
<div class="toolbar">
    <h1>Stránky</h1>
    <a class="btn primary" href="{{ app.adminPath }}/pages/new">+ Nová</a>
</div>
<table class="pages">
    <thead>
        <tr>
            <th>Titulek</th>
            <th>URL</th>
            <th>Stav</th>
            <th>Aktualizováno</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    {% for p in pages %}
        {% set editPath = p.urlPath == '/' ? '~' : p.urlPath|trim('/') %}
        <tr>
            <td style="padding-left: calc(0.9rem + {{ p.depth() * 1.2 }}rem)">
                <a href="{{ app.adminPath }}/pages/{{ editPath }}/edit">{{ p.title }}</a>
            </td>
            <td><code>{{ p.urlPath }}</code></td>
            <td>
                {% if p.published %}
                    <span class="tag ok">publikováno</span>
                {% else %}
                    <span class="tag">koncept</span>
                {% endif %}
            </td>
            <td>{{ p.updated }}</td>
            <td>
                <details class="row-actions">
                    <summary>⋯</summary>
                    <div class="menu">
                        <a href="{{ app.adminPath }}/pages/new?parent={{ p.urlPath|url_encode }}">+ Přidat podstránku</a>
                        <a href="{{ app.adminPath }}/pages/{{ editPath }}/edit">Upravit</a>
                        {% if p.urlPath != '/' %}
                        <form method="post" action="{{ app.adminPath }}/pages/{{ editPath }}/delete"
                              onsubmit="return confirm('Smazat {{ p.urlPath }}?');">
                            <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
                            <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
                            <button type="submit" class="danger">Smazat</button>
                        </form>
                        {% endif %}
                    </div>
                </details>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="5" class="empty">Žádné stránky. <a href="{{ app.adminPath }}/pages/new">Vytvořit první.</a></td></tr>
    {% endfor %}
    </tbody>
</table>
<script>
(() => {
    // Position a fixed dropdown next to its summary button, flipping above
    // when there isn't enough room below. The menu lives inside the row but
    // escapes the table's overflow:hidden because position:fixed is anchored
    // to the viewport.
    function place(details) {
        const summary = details.querySelector('summary');
        const menu    = details.querySelector('.menu');
        if (!summary || !menu) return;
        const r = summary.getBoundingClientRect();
        const mh = menu.offsetHeight;
        const mw = menu.offsetWidth;
        const below = window.innerHeight - r.bottom;
        const top = (below > mh + 8 || below > r.top) ? r.bottom + 4 : r.top - mh - 4;
        const left = Math.max(8, Math.min(r.right - mw, window.innerWidth - mw - 8));
        menu.style.top  = top  + 'px';
        menu.style.left = left + 'px';
    }

    document.querySelectorAll('details.row-actions').forEach(d => {
        d.addEventListener('toggle', () => { if (d.open) place(d); });
    });

    // Reposition any open menu on scroll/resize.
    const reposition = () => document.querySelectorAll('details.row-actions[open]').forEach(place);
    window.addEventListener('scroll', reposition, true);
    window.addEventListener('resize', reposition);

    // Close any open menu when clicking outside.
    document.addEventListener('click', e => {
        document.querySelectorAll('details.row-actions[open]').forEach(d => {
            if (!d.contains(e.target)) d.open = false;
        });
    });
})();
</script>
{% endblock %}
