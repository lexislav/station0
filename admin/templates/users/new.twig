{% extends '@admin/layout.twig' %}
{% block body %}
<h1>{{ t.user_new_title }}</h1>
{% if error %}<p class="error">{{ error }}</p>{% endif %}
<form method="post" action="{{ app.adminPath }}/users" class="form-narrow">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <div class="field"><label>{{ t.user_field_username }}<input type="text" name="username" required autocomplete="username"></label></div>
    <div class="field"><label>{{ t.user_field_email }}<input type="email" name="email" required></label></div>
    <div class="field"><label>{{ t.user_field_password }}<input type="password" name="password" minlength="8" required></label></div>
    <div class="field"><label>{{ t.user_field_role }}
        <select name="role">
            {% for r in roles %}<option value="{{ r }}">{{ r }}</option>{% endfor %}
        </select>
    </label></div>
    <div class="toolbar">
        <a class="btn" href="{{ app.adminPath }}/users">{{ t.user_cancel }}</a>
        <button type="submit" class="btn primary">{{ t.user_create }}</button>
    </div>
</form>
{% endblock %}
