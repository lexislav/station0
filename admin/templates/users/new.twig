{% extends '@admin/layout.twig' %}
{% block body %}
<h1>New user</h1>
{% if error %}<p class="error">{{ error }}</p>{% endif %}
<form method="post" action="{{ app.adminPath }}/users" class="form-narrow">
    <input type="hidden" name="{{ csrf.nameKey }}" value="{{ csrf.name }}">
    <input type="hidden" name="{{ csrf.valueKey }}" value="{{ csrf.value }}">
    <div class="field"><label>Username<input type="text" name="username" required autocomplete="username"></label></div>
    <div class="field"><label>E-mail<input type="email" name="email" required></label></div>
    <div class="field"><label>Password<input type="password" name="password" minlength="8" required></label></div>
    <div class="field"><label>Role
        <select name="role">
            {% for r in roles %}<option value="{{ r }}">{{ r }}</option>{% endfor %}
        </select>
    </label></div>
    <div class="toolbar">
        <a class="btn" href="{{ app.adminPath }}/users">Cancel</a>
        <button type="submit" class="btn primary">Create</button>
    </div>
</form>
{% endblock %}
