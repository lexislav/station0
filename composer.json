{
    "name": "lexislav/station0",
    "description": "Grand zero flat file CMS — core library.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo_sqlite": "*",
        "delight-im/auth": "^9.0",
        "league/commonmark": "^2.4",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "slim/csrf": "^1.3",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13",
        "slim/twig-view": "^3.3",
        "symfony/yaml": "^8.0",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Station0\\": "src/"
        }
    },
    "bin": [
        "bin/console"
    ],
    "config": {
        "sort-packages": true
    }
}
