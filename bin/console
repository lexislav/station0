#!/usr/bin/env php
<?php

declare(strict_types=1);

$station0Root = dirname(__DIR__);

// vendor/lexislav/station0 → vendor/lexislav → vendor → project root
$projectRoot = dirname($station0Root, 3);
if (!is_dir($projectRoot . '/vendor')) {
    $projectRoot = dirname($station0Root); // fallback for direct clone
}

require $projectRoot . '/vendor/autoload.php';

$dotenv = Dotenv\Dotenv::createImmutable($projectRoot);
$dotenv->safeLoad();

use Delight\Auth\Auth;
use Station0\Service\ContentRepository;
use Station0\Service\FileCache;
use Station0\Service\UserRepository;
use Symfony\Component\Yaml\Yaml;

$siteRoot = rtrim(getenv('SITE_PATH') ?: ($projectRoot . '/site'), '/');
$configFactory = require $siteRoot . '/config.php';
$config = $configFactory($station0Root, $siteRoot, $projectRoot);
$roles = require $station0Root . '/config/roles.php';

foreach ([$config['paths']['cache'], $config['paths']['sessions'], $config['paths']['logs'], $config['paths']['uploads']] as $dir) {
    if (!is_dir($dir)) {
        @mkdir($dir, 0775, true);
    }
}

$pdo = (function () use ($config) {
    $fresh = !file_exists($config['paths']['db']);
    $pdo = new \PDO('sqlite:' . $config['paths']['db']);
    $pdo->setAttribute(\PDO::ATTR_ERRMODE, \PDO::ERRMODE_EXCEPTION);
    if ($fresh) {
        $pdo->exec(file_get_contents($projectRoot . '/vendor/delight-im/auth/Database/SQLite.sql'));
    }
    return $pdo;
})();

ini_set('session.use_cookies', '0');
ini_set('session.use_only_cookies', '0');
ini_set('session.cache_limiter', '');
@session_start();

$auth = new Auth($pdo);
$users = new UserRepository($auth, $pdo, $roles);

$command = $argv[1] ?? 'help';
$args = array_slice($argv, 2);

switch ($command) {
    case 'user:create':
        [$username, $email, $role] = [$args[0] ?? null, $args[1] ?? null, $args[2] ?? 'editor'];
        if (!$username || !$email) {
            fwrite(STDERR, "Usage: bin/console user:create <username> <email> [role]\n");
            exit(1);
        }
        echo "Heslo pro {$username}: ";
        system('stty -echo');
        $pw = trim((string) fgets(STDIN));
        system('stty echo');
        echo "\n";
        if (strlen($pw) < 8) {
            fwrite(STDERR, "Heslo musí mít alespoň 8 znaků.\n");
            exit(1);
        }
        $id = $users->create($email, $pw, $role, $username);
        echo "Uživatel vytvořen (id={$id}, username={$username}, role={$role}).\n";
        break;

    case 'user:reset-password':
        $email = $args[0] ?? null;
        if (!$email) {
            fwrite(STDERR, "Usage: bin/console user:reset-password <email>\n");
            exit(1);
        }
        $stmt = $pdo->prepare('SELECT id FROM users WHERE email = :e');
        $stmt->execute([':e' => $email]);
        $id = (int) $stmt->fetchColumn();
        if (!$id) {
            fwrite(STDERR, "Uživatel {$email} neexistuje.\n");
            exit(1);
        }
        echo "Nové heslo: ";
        system('stty -echo');
        $pw = trim((string) fgets(STDIN));
        system('stty echo');
        echo "\n";
        if (strlen($pw) < 8) {
            fwrite(STDERR, "Heslo musí mít alespoň 8 znaků.\n");
            exit(1);
        }
        $users->setPassword($id, $pw);
        echo "Heslo změněno.\n";
        break;

    case 'cache:clear':
        $cache = new FileCache($config['paths']['cache']);
        $n = $cache->flush();
        echo "Smazáno {$n} položek cache.\n";
        break;

    case 'assets:relink':
        $dryRun = in_array('--dry-run', $args, true);
        $repo   = new ContentRepository($config['paths']['content'] . '/pages');
        $changedFiles = 0;
        $changedRefs  = 0;

        foreach ($repo->all() as $page) {
            if (!$page->filePath || !is_file($page->filePath)) {
                continue;
            }
            $raw = (string) file_get_contents($page->filePath);
            // Split front matter from body — only the body holds asset references.
            $sep = strpos($raw, "\n---\n");
            if ($sep === false) {
                continue;
            }
            $head = substr($raw, 0, $sep + 5);
            $body = substr($raw, $sep + 5);

            // Local prefix to strip: /media/{page-url-path}/  (or /media/~/ for root)
            $prefix = $page->urlPath === '/'
                ? '/media/~/'
                : '/media' . rtrim($page->urlPath, '/') . '/';

            $count = 0;
            $newBody = preg_replace_callback(
                '#' . preg_quote($prefix, '#') . '([A-Za-z0-9._\-]+)#',
                function (array $m) use (&$count) { $count++; return $m[1]; },
                $body,
            ) ?? $body;

            if ($count === 0) {
                continue;
            }
            $changedFiles++;
            $changedRefs += $count;
            echo ($dryRun ? '[dry] ' : '') . "{$page->urlPath}: {$count} ref(s)\n";

            if (!$dryRun) {
                file_put_contents($page->filePath, $head . $newBody);
            }
        }

        echo ($dryRun ? '[dry] ' : '') . "Hotovo: {$changedRefs} reference(í) v {$changedFiles} stránk(ách).\n";
        if (!$dryRun && $changedFiles > 0) {
            (new FileCache($config['paths']['cache']))->flush();
        }
        break;

    case 'help':
    default:
        echo "Station0 console\n";
        echo "  user:create <username> <email> [role]    Vytvoří uživatele (role: admin|editor)\n";
        echo "  user:reset-password <email>   Resetuje heslo\n";
        echo "  cache:clear                   Vyčistí cache obsahu\n";
        echo "  assets:relink [--dry-run]     Převede absolutní /media/... odkazy na page-local názvy\n";
        break;
}
